#: extension.js:242
msgid "Show desktop"
msgstr "Показать рабочий стол"

#: prefs.js:22
msgid "Left"
msgstr "Слева"

#: prefs.js:23
msgid "Center"
msgstr "По центру"

#: prefs.js:24
msgid "Right"
msgstr "Справа"

#: prefs.js:28
msgid "Taskbar"
msgstr "Панель задач"

#: prefs.js:34
msgid "Start Menu"
msgstr "Меню «Пуск»"

#: prefs.js:40 prefs.js:491
msgid "Start Button"
msgstr "Кнопка «Пуск»"

#: prefs.js:41
msgid "Configure the Start button position and spacing."
msgstr "Настройте положение и отступы кнопки «Пуск»."

#: prefs.js:46 prefs.js:571
msgid "Eleven-style Start Menu"
msgstr "Eleven-style Start Menu"

#: prefs.js:47
msgid "Configure the optional Eleven-style application menu."
msgstr "Настройте дополнительное меню приложений Eleven-style."

#: prefs.js:66
msgid "Panel Mode"
msgstr "Режим панели"

#: prefs.js:71
msgid "Default GNOME Panel"
msgstr "Стандартная панель GNOME"

#: prefs.js:72
msgid "Hide taskbar applications and use the original Dash in Overview"
msgstr "Скрыть приложения панели задач и использовать оригинальный Dash в обзоре"

#: prefs.js:78
msgid "Application Icons"
msgstr "Значки приложений"

#: prefs.js:79 prefs.js:195
msgid "Change the size, spacing, and placement of taskbar icons."
msgstr "Измените размер, расстояние и расположение значков панели задач."

#: prefs.js:85
msgid "Icon Size"
msgstr "Размер значков"

#: prefs.js:86
msgid "The panel grows automatically when larger icons need more room"
msgstr "Панель автоматически расширяется, когда крупные значки требуют больше места"

#: prefs.js:92
msgid "Icon Spacing"
msgstr "Расстояние между значками"

#: prefs.js:93
msgid "Space between application buttons"
msgstr "Расстояние между кнопками приложений"

#: prefs.js:99
msgid "Icon Alignment"
msgstr "Выравнивание значков"

#: prefs.js:100
msgid "Place application icons at the left or center"
msgstr "Расположить значки приложений слева или по центру"

#: prefs.js:105
msgid "Hide Pinned Applications"
msgstr "Скрыть закреплённые приложения"

#: prefs.js:106
msgid "Show pinned taskbar applications only while they are running"
msgstr "Показывать закреплённые приложения панели задач только во время их работы"

#: prefs.js:124
msgid "Combine Application Buttons"
msgstr "Объединить кнопки приложений"

#: prefs.js:125
msgid "Choose when windows share one taskbar button"
msgstr "Выберите, когда окна объединяются в одну кнопку на панели задач"

#: prefs.js:127
msgid "Always"
msgstr "Всегда"

#: prefs.js:128
msgid "Only When Full"
msgstr "Только при заполнении"

#: prefs.js:129
msgid "Never"
msgstr "Никогда"

#: prefs.js:135
msgid "Hide App Labels"
msgstr "Скрыть подписи приложений"

#: prefs.js:136
msgid "Show only icons on separate window buttons"
msgstr "Показывать только значки на раздельных кнопках окон"

#: prefs.js:157
msgid "Isolate Workspaces"
msgstr "Изолировать рабочие столы"

#: prefs.js:158
msgid "Show running applications from the current workspace only"
msgstr "Показывать запущенные приложения только с текущего рабочего стола"

#: prefs.js:170
msgid "Spread Multiple Windows"
msgstr "Развернуть несколько окон"

#: prefs.js:171
msgid ""
"Click an app with multiple windows to show only its windows in Overview, "
"across all workspaces"
msgstr "Нажмите на приложение с несколькими окнами, чтобы показать только его окна в обзоре, на всех рабочих столах"

#: prefs.js:194
msgid "Application icons are unavailable in Default GNOME Panel mode."
msgstr "Значки приложений недоступны в режиме стандартной панели GNOME."

#: prefs.js:254
msgid "Panel Appearance"
msgstr "Внешний вид панели"

#: prefs.js:255
msgid "Change the taskbar height, colour scheme, and transparency."
msgstr "Измените высоту, цветовую схему и прозрачность панели задач."

#: prefs.js:261
msgid "Panel Height"
msgstr "Высота панели"

#: prefs.js:262
msgid "Oversized icons shrink automatically when the panel is reduced"
msgstr "Крупные значки автоматически уменьшаются при уменьшении панели"

#: prefs.js:268
msgid "Panel Position"
msgstr "Положение панели"

#: prefs.js:269
msgid "Place the taskbar at the top or bottom of the screen"
msgstr "Расположить панель задач вверху или внизу экрана"

#: prefs.js:271
msgid "Top"
msgstr "Вверху"

#: prefs.js:272
msgid "Bottom"
msgstr "Внизу"

#: prefs.js:303
msgid "Follow System Theme"
msgstr "Следовать системной теме"

#: prefs.js:304
msgid ""
"Match the active GNOME Shell theme, independently of application colours"
msgstr "Использовать активную тему GNOME Shell независимо от цвета приложений"

#: prefs.js:320
msgid "Taskbar Theme"
msgstr "Тема панели задач"

#: prefs.js:321
msgid "Choose the colour scheme when system matching is off"
msgstr "Выберите цветовую схему, когда системное соответствие отключено"

#: prefs.js:323 prefs.js:629
msgid "Light"
msgstr "Светлая"

#: prefs.js:324 prefs.js:628
msgid "Dark"
msgstr "Тёмная"

#: prefs.js:334
msgid "Enable Transparency"
msgstr "Включить прозрачность"

#: prefs.js:335
msgid "Make the taskbar background transparent"
msgstr "Сделать фон панели задач прозрачным"

#: prefs.js:351
msgid "Transparency"
msgstr "Прозрачность"

#: prefs.js:352
msgid "0% is opaque and 100% is fully transparent"
msgstr "0% — непрозрачно, 100% — полностью прозрачно"

#: prefs.js:363
msgid "Taskbar Behavior"
msgstr "Поведение панели задач"

#: prefs.js:368
msgid "Auto-hide Panel"
msgstr "Автоскрытие панели"

#: prefs.js:369
msgid "Reveal the taskbar when the pointer reaches its screen edge"
msgstr "Показывать панель задач, когда указатель достигает края экрана"

#: prefs.js:381
msgid "Workspace Scroll"
msgstr "Прокрутка рабочих столов"

#: prefs.js:382
msgid "Scroll over empty taskbar space to switch workspaces"
msgstr "Прокручивайте пустое пространство панели задач для переключения рабочих столов"

#: prefs.js:398
msgid "Workspace Scroll Delay"
msgstr "Задержка прокрутки рабочих столов"

#: prefs.js:399
msgid "Minimum delay between workspace changes in milliseconds"
msgstr "Минимальная задержка между переключениями рабочих столов в миллисекундах"

#: prefs.js:411
msgid "Panel Menus Require Click"
msgstr "Меню панели открываются по щелчку"

#: prefs.js:412
msgid "Switch between clock, system, and tray menus only when clicked"
msgstr "Переключаться между меню часов, системы и трея только по щелчку"

#: prefs.js:424
msgid "Taskbar-aligned Notification Banners"
msgstr "Уведомления вдоль панели задач"

#: prefs.js:425
msgid "Follow the taskbar edge and the clock’s horizontal position"
msgstr "Следовать краю панели задач и горизонтальному положению часов"

#: prefs.js:452
#, javascript-format
msgid "%s (Unavailable)"
msgstr "%s (недоступно)"

#: prefs.js:463
msgid "Task Manager Application"
msgstr "Приложение диспетчера задач"

#: prefs.js:464
msgid "Application opened from the taskbar context menu"
msgstr "Приложение, открываемое из контекстного меню панели задач"

#: prefs.js:471
msgid "Show Taskbar on All Monitors"
msgstr "Показывать панель задач на всех мониторах"

#: prefs.js:472
msgid "Show Activities, applications, clock, and system menu on every monitor"
msgstr "Показывать «Деятельность», приложения, часы и системное меню на каждом мониторе"

#: prefs.js:484
msgid "Panel Items"
msgstr "Элементы панели"

#: prefs.js:485
msgid "Choose where taskbar and system items appear."
msgstr "Выберите, где отображаются элементы панели задач и системы."

#: prefs.js:492
msgid "Place the Start button at the left edge or in the center"
msgstr "Расположить кнопку «Пуск» у левого края или по центру"

#: prefs.js:497
msgid "Follow Application Alignment"
msgstr "Следовать выравниванию приложений"

#: prefs.js:498
msgid "Move the Start button with the application buttons"
msgstr "Перемещать кнопку «Пуск» вместе с кнопками приложений"

#: prefs.js:521
msgid "Start Button Padding"
msgstr "Отступ кнопки «Пуск»"

#: prefs.js:522
msgid "Horizontal space around the Start icon in pixels"
msgstr "Горизонтальное пространство вокруг значка «Пуск» в пикселях"

#: prefs.js:528
msgid "Custom Start Button Icon"
msgstr "Пользовательский значок кнопки «Пуск»"

#: prefs.js:532
msgid "Use the built-in icon"
msgstr "Использовать встроенный значок"

#: prefs.js:536 prefs.js:801
msgid "Choose…"
msgstr "Выбрать…"

#: prefs.js:554
msgid "Using the built-in icon"
msgstr "Используется встроенный значок"

#: prefs.js:572
msgid "Replace the GNOME app grid with an Eleven-style menu"
msgstr "Заменить сетку приложений GNOME меню Eleven-style"

#: prefs.js:584
msgid "Show Original GNOME Button"
msgstr "Показать оригинальную кнопку GNOME"

#: prefs.js:585
msgid ""
"Show the Applications button when the Eleven-style Start Menu is disabled"
msgstr "Показывать кнопку «Приложения», когда Eleven-style Start Menu отключено"

#: prefs.js:606
msgid "Follow Panel Theme"
msgstr "Следовать теме панели"

#: prefs.js:607
msgid "Use the panel’s effective light or dark appearance"
msgstr "Использовать текущую светлую или тёмную тему панели"

#: prefs.js:625
msgid "Start Menu Theme"
msgstr "Тема меню «Пуск»"

#: prefs.js:626
msgid "Use a custom appearance or follow the GNOME Shell theme"
msgstr "Использовать пользовательский вид или следовать теме GNOME Shell"

#: prefs.js:630
msgid "GNOME Shell"
msgstr "GNOME Shell"

#: prefs.js:650
msgid "Center Start Menu on Monitor"
msgstr "Центрировать меню «Пуск» на мониторе"

#: prefs.js:651
msgid ""
"Place the menu at the true horizontal center instead of over the Start button"
msgstr "Расположить меню по настоящему центру экрана, а не над кнопкой «Пуск»"

#: prefs.js:686
msgid "Super+Tab Opens Start Menu"
msgstr "Super+Tab открывает меню «Пуск»"

#: prefs.js:687
msgid ""
"Use GNOME’s application-switch shortcut for the Eleven-style Start Menu "
"while it is enabled"
msgstr "Использовать сочетание клавиш переключения приложений GNOME для Eleven-style Start Menu, пока оно включено"

#: prefs.js:707
msgid "Not set"
msgstr "Не задано"

#: prefs.js:712
msgid "Set custom shortcut"
msgstr "Задать пользовательское сочетание клавиш"

#: prefs.js:717
msgid "Clear custom shortcut"
msgstr "Очистить пользовательское сочетание клавиш"

#: prefs.js:721
msgid "Custom Start Menu Shortcut"
msgstr "Пользовательское сочетание клавиш меню «Пуск»"

#: prefs.js:738
msgid "Turn off Super+Tab to use a custom shortcut"
msgstr "Отключите Super+Tab, чтобы использовать пользовательское сочетание клавиш"

#: prefs.js:739
msgid "Choose any unused keyboard shortcut; none is assigned by default"
msgstr "Выберите любое свободное сочетание клавиш; по умолчанию не назначено"

#: prefs.js:760
msgid "Show Activities Button"
msgstr "Показать кнопку «Деятельность»"

#: prefs.js:761
msgid "Display GNOME’s workspace overview button on the taskbar"
msgstr "Показывать кнопку обзора рабочих столов GNOME на панели задач"

#: prefs.js:774
msgid "Clock"
msgstr "Часы"

#: prefs.js:779
msgid "System Menu"
msgstr "Системное меню"

#: prefs.js:780
msgid "Quick Settings, volume, network, and power"
msgstr "Быстрые настройки, громкость, сеть и питание"

#: prefs.js:785
msgid "Show Folder Menu"
msgstr "Показать меню папки"

#: prefs.js:786
msgid "Place a selected folder on the right of the taskbar"
msgstr "Разместить выбранную папку справа на панели задач"

#: prefs.js:798
msgid "Folder Menu Location"
msgstr "Расположение меню папки"

#: prefs.js:816
msgid "No folder selected"
msgstr "Папка не выбрана"

#: prefs.js:831 prefs.js:858
msgid "Reset"
msgstr "Сбросить"

#: prefs.js:836
msgid "Reset All Settings"
msgstr "Сбросить все настройки"

#: prefs.js:837
msgid "Restore defaults without changing pinned taskbar apps"
msgstr "Восстановить настройки по умолчанию без изменения закреплённых приложений"

#: prefs.js:840
msgid "Reset…"
msgstr "Сбросить…"

#: prefs.js:854
msgid "Reset all settings?"
msgstr "Сбросить все настройки?"

#: prefs.js:855
msgid ""
"This will restore taskbar and Start menu settings, including pinned Start "
"apps. Pinned taskbar apps and their order will be kept."
msgstr "Это восстановит настройки панели задач и меню «Пуск», включая закреплённые приложения. Закреплённые приложения панели задач и их порядок сохранятся."

#: prefs.js:857
msgid "Cancel"
msgstr "Отмена"

#: prefs.js:892
msgid "Set Custom Shortcut"
msgstr "Задать пользовательское сочетание клавиш"

#: prefs.js:905
msgid "Press a keyboard shortcut"
msgstr "Нажмите сочетание клавиш"

#: prefs.js:906
msgid "Press Backspace to clear it, or Escape to cancel."
msgstr "Нажмите Backspace для очистки или Escape для отмены."

#: prefs.js:950
msgid "That shortcut needs a modifier key. Try another shortcut."
msgstr "Это сочетание клавиш требует клавишу-модификатор. Попробуйте другое сочетание."

#: prefs.js:961
msgid "That shortcut is already in use. Press a different shortcut."
msgstr "Это сочетание клавиш уже используется. Нажмите другое сочетание."

#: prefs.js:979
msgid "Image Files"
msgstr "Файлы изображений"

#: prefs.js:995
msgid "Choose a Start Button Icon"
msgstr "Выберите значок кнопки «Пуск»"

#: prefs.js:1015
msgid "Choose a Folder"
msgstr "Выберите папку"

#: windowsStartMenu.js:327
msgid "Type here to search"
msgstr "Введите текст для поиска"

#: windowsStartMenu.js:377 windowsStartMenu.js:534
msgid "Pinned"
msgstr "Закреплённые"

#: windowsStartMenu.js:382 windowsStartMenu.js:566
msgid "All apps"
msgstr "Все приложения"

#: windowsStartMenu.js:391
msgid "Back"
msgstr "Назад"

#: windowsStartMenu.js:466
msgid "Settings"
msgstr "Настройки"

#: windowsStartMenu.js:549
msgid "Choose All, then right-click an app to pin it"
msgstr "Выберите «Все», затем нажмите правой кнопкой на приложение, чтобы закрепить его"

#: windowsStartMenu.js:558
msgid "Recommended"
msgstr "Рекомендуемые"

#: windowsStartMenu.js:574
msgid "Search results"
msgstr "Результаты поиска"

#: windowsStartMenu.js:592
msgid "No results found"
msgstr "Результаты не найдены"

#: taskbarAppMenu.js:15
msgid "Unpin from Taskbar"
msgstr "Открепить от панели задач"

#: taskbarAppMenu.js:16
msgid "Pin to Taskbar"
msgstr "Закрепить на панели задач"

#: startMenuAppMenu.js:201
msgid "Unpin from Start"
msgstr "Открепить от «Пуск»"

#: startMenuAppMenu.js:202
msgid "Pin to Start"
msgstr "Закрепить в «Пуск»"

#: startMenuAppMenu.js:111 startMenuAppMenu.js:268
msgid "Create Desktop Shortcut"
msgstr "Создать ярлык на рабочем столе"

#: startMenuAppMenu.js:267
msgid "Delete Desktop Shortcut"
msgstr "Удалить ярлык с рабочего стола"

#: folderMenuController.js:46 folderMenuController.js:188
msgid "Folder menu"
msgstr "Меню папки"

#: folderMenuController.js:65
msgid "Open to view folder contents"
msgstr "Откройте для просмотра содержимого папки"

#: folderMenuController.js:189
msgid "Choose a folder in Taskbar Settings"
msgstr "Выберите папку в настройках панели задач"

#: folderMenuController.js:196
#, javascript-format
msgid "%s folder"
msgstr "Папка «%s»"

#: folderMenuController.js:198
msgid "Selected"
msgstr "Выбрана"

#: folderMenuController.js:200
msgid "Loading…"
msgstr "Загрузка…"

#: folderMenuController.js:298
msgid "This folder is empty"
msgstr "Эта папка пуста"

#: startButtonController.js:170
msgid "Start Menu Settings"
msgstr "Настройки меню «Пуск»"

#: startButtonController.js:358
msgid "Start"
msgstr "Пуск"

#: startButtonController.js:358
msgid "Applications"
msgstr "Приложения"

#: panelInteractionController.js:95
msgid "Task Manager"
msgstr "Диспетчер задач"

#: panelInteractionController.js:97
msgid "Lock the Taskbar"
msgstr "Заблокировать панель задач"

#: panelInteractionController.js:127
msgid "Taskbar Settings"
msgstr "Настройки панели задач"

#: taskbarController.js:432 taskbarController.js:434 taskbarController.js:1341
msgid "running"
msgstr "запущено"

#: windowPreviewController.js:560
msgid "Untitled Window"
msgstr "Безымянное окно"

#: windowPreviewController.js:603
msgid "Close Window"
msgstr "Закрыть окно"

#: favoritesIntegration.js:36
#, javascript-format
msgid "%s has been pinned to the taskbar."
msgstr "%s закреплён на панели задач."

#: favoritesIntegration.js:59
#, javascript-format
msgid "%s has been unpinned from the taskbar."
msgstr "%s откреплён от панели задач."
